    "body": "<!DOCTYPE html>\n<html lang=\"ko\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Sportition — Portfolio</title>\n<style>\n@import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=JetBrains+Mono:wght@300;400;500&family=Noto+Sans+KR:wght@300;400;500;700&display=swap');\n\n:root {\n  --bg:      #0e0d0b;\n  --bg2:     #161512;\n  --bg3:     #1e1c18;\n  --bg4:     #262420;\n  --border:  rgba(255,255,255,0.05);\n  --border2: rgba(255,255,255,0.10);\n  --text:    #e8e4dc;\n  --text2:   #9e9a91;\n  --text3:   #5c5850;\n  --red:     #c0392b;\n  --gold:    #c8a96e;\n  --mono: 'JetBrains Mono', monospace;\n  --sans: 'Noto Sans KR', sans-serif;\n  --disp: 'Bebas Neue', sans-serif;\n}\n*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\nhtml { scroll-behavior: smooth; }\nbody { background: var(--bg); color: var(--text); font-family: var(--sans); font-size: 14px; line-height: 1.7; overflow-x: hidden; }\n\nbody::before {\n  content:''; position:fixed; inset:0; pointer-events:none; z-index:0;\n  background-image:url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E\");\n  opacity:.025;\n}\n\n/* HERO */\n.hero { position:relative; min-height:100svh; display:grid; place-items:center; overflow:hidden; }\n#hero-canvas { position:absolute; inset:0; width:100%; height:100%; }\n.hero-inner {\n  position:relative; z-index:2; max-width:860px; width:100%; padding:80px 40px 100px;\n  display:grid; grid-template-columns:1fr 1fr; gap:60px; align-items:end;\n}\n.hero-kicker {\n  font-family:var(--mono); font-size:11px; color:var(--red);\n  letter-spacing:.16em; text-transform:uppercase; margin-bottom:14px;\n  display:flex; align-items:center; gap:10px;\n}\n.hero-kicker::before { content:''; display:block; width:20px; height:1px; background:var(--red); }\n.hero-title { font-family:var(--disp); font-size:clamp(68px,10vw,114px); line-height:.95; margin-bottom:20px; }\n.hero-title .r { color:var(--red); display:block; }\n.hero-desc { color:var(--text2); font-size:14px; line-height:1.85; max-width:340px; margin-bottom:28px; }\n.hero-chips { display:flex; flex-wrap:wrap; gap:6px; }\n.chip { font-family:var(--mono); font-size:10px; color:var(--text3); padding:4px 10px; border-radius:4px; background:rgba(255,255,255,.03); border:0.5px solid var(--border2); letter-spacing:.04em; transition:border-color .2s,color .2s; }\n.chip:hover { border-color:rgba(192,57,43,.5); color:var(--text); }\n.hero-right { display:flex; flex-direction:column; gap:10px; }\n.hero-stat { border-left:1.5px solid var(--border2); padding:10px 18px; transition:border-color .2s; cursor:default; }\n.hero-stat:hover { border-color:var(--red); }\n.stat-n { font-family:var(--disp); font-size:40px; color:var(--text); line-height:1; }\n.stat-n .u { font-family:var(--mono); font-size:13px; color:var(--text3); margin-left:3px; vertical-align:middle; }\n.stat-l { font-size:10px; color:var(--text3); font-family:var(--mono); margin-top:3px; letter-spacing:.05em; }\n.hero-scroll { position:absolute; bottom:32px; left:40px; z-index:2; font-family:var(--mono); font-size:10px; color:var(--text3); letter-spacing:.12em; writing-mode:vertical-rl; display:flex; align-items:center; gap:10px; animation:breathe 3s ease-in-out infinite; }\n.hero-scroll::after { content:''; display:block; width:1px; height:28px; background:var(--text3); }\n@keyframes breathe { 0%,100%{opacity:.3}50%{opacity:.7} }\n\n/* SHARED */\n.section { position:relative; z-index:1; }\n.si { max-width:860px; margin:0 auto; padding:0 40px; }\n.label-tag { font-family:var(--mono); font-size:10px; color:var(--red); letter-spacing:.14em; text-transform:uppercase; display:block; margin-bottom:8px; }\n.big-head { font-family:var(--disp); font-size:clamp(36px,5vw,52px); line-height:1.05; margin-bottom:36px; }\n\n/* PROBLEM */\n.problem-section { padding:100px 0; border-top:0.5px solid var(--border); }\n.problem-layout { display:grid; grid-template-columns:180px 1fr; gap:56px; align-items:start; }\n.problem-sticky { position:sticky; top:100px; }\n.problem-sticky .big-head { font-size:clamp(28px,4vw,40px); margin-bottom:0; }\n.problem-list { display:flex; flex-direction:column; }\n.pi {\n  display:grid; grid-template-columns:1fr 1px 1fr; gap:0;\n  border-bottom:0.5px solid var(--border); padding:22px 0;\n  opacity:0; transform:translateY(10px); transition:opacity .5s,transform .5s;\n}\n.pi:first-child { border-top:0.5px solid var(--border); }\n.pi.vis { opacity:1; transform:none; }\n.dv { background:var(--border); }\n.pc { padding:0 20px; }\n.pc:first-child { padding-left:0; }\n.col-h { font-size:10px; font-family:var(--mono); color:var(--text3); letter-spacing:.08em; text-transform:uppercase; margin-bottom:8px; }\n.prob-t { font-size:13px; color:var(--text2); line-height:1.7; }\n.sol-t { font-size:13px; color:var(--text); line-height:1.7; }\n.sol-t strong { color:var(--gold); font-weight:500; }\n\n/* BUILT */\n.built-section { padding:100px 0; border-top:0.5px solid var(--border); }\n.built-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:1px; background:var(--border); border-radius:14px; overflow:hidden; }\n.bc { background:var(--bg2); padding:22px 18px; transition:background .2s; opacity:0; transform:translateY(8px); transition:opacity .4s,transform .4s,background .2s; }\n.bc.vis { opacity:1; transform:none; }\n.bc:hover { background:var(--bg3); }\n.bc-index { font-family:var(--mono); font-size:10px; color:var(--text3); letter-spacing:.08em; margin-bottom:12px; }\n.bc-name { font-size:13px; font-weight:600; color:var(--text); margin-bottom:5px; }\n.bc-desc { font-size:11px; color:var(--text3); line-height:1.65; }\n.bc-tag { display:inline-block; margin-top:10px; font-size:9px; font-family:var(--mono); color:var(--red); letter-spacing:.06em; text-transform:uppercase; }\n\n/* TECH */\n.tech-section { padding:100px 0; border-top:0.5px solid var(--border); }\n.tech-list { display:flex; flex-direction:column; }\n.tr {\n  display:grid; grid-template-columns:200px 1fr 190px; align-items:center;\n  border-bottom:0.5px solid var(--border); padding:20px 0;\n  opacity:0; transform:translateX(-10px); transition:opacity .4s,transform .4s;\n}\n.tr:first-child { border-top:0.5px solid var(--border); }\n.tr.vis { opacity:1; transform:none; }\n.tr-name { display:flex; align-items:center; gap:12px; }\n.td { width:8px; height:8px; border-radius:50%; flex-shrink:0; }\n.tn { font-size:15px; font-weight:600; color:var(--text); }\n.tc { font-size:10px; font-family:var(--mono); color:var(--text3); letter-spacing:.05em; margin-top:2px; }\n.tr-why { padding:0 28px; font-size:12px; color:var(--text2); line-height:1.7; }\n.tr-dec { font-size:11px; font-family:var(--mono); color:var(--text3); border-left:0.5px solid var(--border); padding-left:22px; line-height:1.65; }\n.dec-lbl { color:var(--gold); display:block; margin-bottom:3px; font-size:9px; letter-spacing:.08em; text-transform:uppercase; }\n\n/* DECISIONS */\n.decisions-section { padding:100px 0; border-top:0.5px solid var(--border); }\n.dec-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; }\n.dc { background:var(--bg2); border:0.5px solid var(--border); border-radius:12px; padding:24px; opacity:0; transform:translateY(8px); transition:opacity .45s,transform .45s,border-color .2s; }\n.dc.vis { opacity:1; transform:none; }\n.dc:hover { border-color:var(--border2); }\n.dc-num { font-family:var(--mono); font-size:10px; color:var(--text3); margin-bottom:10px; letter-spacing:.08em; }\n.dc-title { font-size:15px; font-weight:600; color:var(--text); margin-bottom:8px; line-height:1.3; }\n.dc-body { font-size:12px; color:var(--text2); line-height:1.8; }\n.dc-body em { color:var(--gold); font-style:normal; }\n\n/* FOOTER */\nfooter { border-top:0.5px solid var(--border); }\n.foot-inner { max-width:860px; margin:0 auto; padding:36px 40px; display:flex; justify-content:space-between; align-items:center; }\n.foot-l { font-family:var(--disp); font-size:22px; color:var(--text3); }\n.foot-r { font-family:var(--mono); font-size:11px; color:var(--text3); text-align:right; line-height:1.8; }\n\n/* RESPONSIVE */\n@media (max-width:700px) {\n  .hero-inner { grid-template-columns:1fr; gap:36px; padding:60px 24px 80px; }\n  .hero-right { flex-direction:row; flex-wrap:wrap; }\n  .hero-stat { padding:8px 14px; }\n  .stat-n { font-size:28px; }\n  .si { padding:0 24px; }\n  .problem-layout { grid-template-columns:1fr; gap:28px; }\n  .problem-sticky { position:static; }\n  .built-grid { grid-template-columns:repeat(2,1fr); }\n  .tr { grid-template-columns:1fr; gap:8px; }\n  .tr-why { padding:0; }\n  .tr-dec { border-left:none; padding-left:0; border-top:0.5px solid var(--border); padding-top:8px; }\n  .dec-grid { grid-template-columns:1fr; }\n  .hero-scroll { display:none; }\n  .foot-inner { flex-direction:column; gap:12px; text-align:center; padding:28px 24px; }\n  .foot-r { text-align:center; }\n}\n::-webkit-scrollbar { width:3px; }\n::-webkit-scrollbar-track { background:var(--bg); }\n::-webkit-scrollbar-thumb { background:var(--bg4); }\n</style>\n</head>\n<body>\n\n<!-- HERO -->\n<section class=\"hero\">\n  <canvas id=\"hero-canvas\"></canvas>\n  <div class=\"hero-inner\">\n    <div>\n      <div class=\"hero-kicker\">Sports Community Platform</div>\n      <h1 class=\"hero-title\">SPORTI<span class=\"r\">TION</span></h1>\n      <p class=\"hero-desc\">권투·격투기 체육관의 출석, 경기 기록, 진급 관리를 검증 가능한 데이터로 전환하는 스포츠 커뮤니티 플랫폼. 선수, 코치, 체육관이 하나의 시스템 안에서 연결된다.</p>\n      <div class=\"hero-chips\">\n        <span class=\"chip\">Next.js 15</span><span class=\"chip\">Supabase</span>\n        <span class=\"chip\">Cloudflare Workers</span><span class=\"chip\">PostgreSQL</span>\n        <span class=\"chip\">React 19</span><span class=\"chip\">Tailwind CSS</span>\n      </div>\n    </div>\n    <div class=\"hero-right\">\n      <div class=\"hero-stat\"><div class=\"stat-n\">4<span class=\"u\">roles</span></div><div class=\"stat-l\">USER ROLES</div></div>\n      <div class=\"hero-stat\"><div class=\"stat-n\">8<span class=\"u\">mod</span></div><div class=\"stat-l\">FEATURE MODULES</div></div>\n      <div class=\"hero-stat\"><div class=\"stat-n\">MVP<span class=\"u\">3</span></div><div class=\"stat-l\">CURRENT PHASE</div></div>\n      <div class=\"hero-stat\"><div class=\"stat-n\">375<span class=\"u\">px</span></div><div class=\"stat-l\">MOBILE FIRST</div></div>\n    </div>\n  </div>\n  <div class=\"hero-scroll\">scroll</div>\n</section>\n\n<!-- PROBLEM / SOLUTION -->\n<section class=\"section problem-section\">\n  <div class=\"si\">\n    <div class=\"problem-layout\">\n      <div class=\"problem-sticky\">\n        <span class=\"label-tag\">01 / Problem</span>\n        <div class=\"big-head\">무엇을<br>해결했나</div>\n      </div>\n      <div class=\"problem-list\">\n        <div class=\"pi\">\n          <div class=\"pc\"><div class=\"col-h\">기존 방식</div><div class=\"prob-t\">출석 기록이 종이나 구두에 의존해 누락과 조작 가능성이 상시 존재했다.</div></div>\n          <div class=\"dv\"></div>\n          <div class=\"pc\"><div class=\"col-h\">해결 방식</div><div class=\"sol-t\">키오스크 기반 출석 시스템으로 전환. <strong>하루 1회 제약을 DB 레벨</strong>에서 강제해 데이터 신뢰성을 확보했다.</div></div>\n        </div>\n        <div class=\"pi\">\n          <div class=\"pc\"><div class=\"col-h\">기존 방식</div><div class=\"prob-t\">선수 진급 기준이 코치의 주관에만 의존해 검증이 불가능했다.</div></div>\n          <div class=\"dv\"></div>\n          <div class=\"pc\"><div class=\"col-h\">해결 방식</div><div class=\"sol-t\"><strong>스킬트리 마스터 + 코치 승인 큐</strong>를 도입해 진급 과정을 정량화하고 이력을 남겼다.</div></div>\n        </div>\n        <div class=\"pi\">\n          <div class=\"pc\"><div class=\"col-h\">기존 방식</div><div class=\"prob-t\">스파링·경기 결과가 메신저에만 남아 누적 전적 관리가 불가능했다.</div></div>\n          <div class=\"dv\"></div>\n          <div class=\"pc\"><div class=\"col-h\">해결 방식</div><div class=\"sol-t\">경기를 <strong>양방향으로 기록</strong>하고 DB 트리거로 통계를 자동 집계. 실시간 전적 조회가 가능해졌다.</div></div>\n        </div>\n        <div class=\"pi\">\n          <div class=\"pc\"><div class=\"col-h\">기존 방식</div><div class=\"prob-t\">체육관 이름을 자유 텍스트로 입력해 오타·중복으로 회원 연결 실패가 반복됐다.</div></div>\n          <div class=\"dv\"></div>\n          <div class=\"pc\"><div class=\"col-h\">해결 방식</div><div class=\"sol-t\"><strong>체육관 코드 시스템</strong>을 설계. 내부 연결 키 / 입력 코드 / 표시 이름을 분리해 구조적으로 해결했다.</div></div>\n        </div>\n        <div class=\"pi\">\n          <div class=\"pc\"><div class=\"col-h\">기존 방식</div><div class=\"prob-t\">훈련이 반복될수록 동기가 저하되는 구조적 문제가 있었다.</div></div>\n          <div class=\"dv\"></div>\n          <div class=\"pc\"><div class=\"col-h\">해결 방식</div><div class=\"sol-t\">스킬 포인트 · 스킬트리 해금 · <strong>가챠 카드 시스템</strong>을 연결해 훈련에 게임화 루프를 설계했다.</div></div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- WHAT I BUILT -->\n<section class=\"section built-section\">\n  <div class=\"si\">\n    <span class=\"label-tag\">02 / Features</span>\n    <div class=\"big-head\">직접 구현한 기능들</div>\n    <div class=\"built-grid\">\n      <div class=\"bc\"><div class=\"bc-index\">01</div><div class=\"bc-name\">역할 기반 인증</div><div class=\"bc-desc\">선수·코치·체육관·관리자 4가지 역할. 역할마다 다른 가입 필드와 화면 접근 권한.</div><span class=\"bc-tag\">Auth · Role System</span></div>\n      <div class=\"bc\"><div class=\"bc-index\">02</div><div class=\"bc-name\">체육관 코드 시스템</div><div class=\"bc-desc\">고유 코드로 체육관 정확히 식별. 회원 이동 시에도 소속 이력이 끊기지 않고 보존.</div><span class=\"bc-tag\">Gym Code · History</span></div>\n      <div class=\"bc\"><div class=\"bc-index\">03</div><div class=\"bc-name\">키오스크 출석</div><div class=\"bc-desc\">태블릿 기반 현장 출석. 한국 시간대 기준 하루 1회 제약, 포인트 적립까지 연동.</div><span class=\"bc-tag\">Kiosk · KST · Points</span></div>\n      <div class=\"bc\"><div class=\"bc-index\">04</div><div class=\"bc-name\">스킬트리</div><div class=\"bc-desc\">선행 노드 조건, 포인트 투자, 코치 승인 큐까지 연결된 단계적 기술 학습 경로.</div><span class=\"bc-tag\">Skill Tree · Approval</span></div>\n      <div class=\"bc\"><div class=\"bc-index\">05</div><div class=\"bc-name\">가챠 시스템</div><div class=\"bc-desc\">4등급 스킬 카드 수집. 조각 합산 레벨업, 천장 보장, 스킬트리 노드 장착 연결.</div><span class=\"bc-tag\">Gacha · Cards · Pity</span></div>\n      <div class=\"bc\"><div class=\"bc-index\">06</div><div class=\"bc-name\">매치 기록 & 전적</div><div class=\"bc-desc\">양방향 경기 기록으로 중복 없는 통계 집계. 매치 입력 즉시 전적이 자동 갱신.</div><span class=\"bc-tag\">Match · Auto Stats</span></div>\n      <div class=\"bc\"><div class=\"bc-index\">07</div><div class=\"bc-name\">프로필 & 아바타</div><div class=\"bc-desc\">공개 정보와 민감 정보를 DB 레벨에서 분리. 스토리지 기반 아바타 업로드 지원.</div><span class=\"bc-tag\">Public / Private · Storage</span></div>\n      <div class=\"bc\"><div class=\"bc-index\">08</div><div class=\"bc-name\">모바일 최적화</div><div class=\"bc-desc\">iPhone SE 375px를 기준으로 설계. 키오스크부터 코치 패널까지 단일 코드베이스.</div><span class=\"bc-tag\">375px · Mobile First</span></div>\n    </div>\n  </div>\n</section>\n\n<!-- TECH STACK -->\n<section class=\"section tech-section\">\n  <div class=\"si\">\n    <span class=\"label-tag\">03 / Stack</span>\n    <div class=\"big-head\">기술 선택과 이유</div>\n    <div class=\"tech-list\">\n      <div class=\"tr\">\n        <div class=\"tr-name\"><div class=\"td\" style=\"background:#fff;opacity:.6\"></div><div><div class=\"tn\">Next.js 15</div><div class=\"tc\">Framework</div></div></div>\n        <div class=\"tr-why\">App Router 기반 SSR과 Cloudflare Workers 엣지 환경 호환성. 모바일·데스크톱을 단일 코드베이스로 처리한다.</div>\n        <div class=\"tr-dec\"><span class=\"dec-lbl\">결정 포인트</span>엣지 배포 + SSR을 동시에 충족하는 선택</div>\n      </div>\n      <div class=\"tr\">\n        <div class=\"tr-name\"><div class=\"td\" style=\"background:#3ecf8e\"></div><div><div class=\"tn\">Supabase</div><div class=\"tc\">BaaS · PostgreSQL</div></div></div>\n        <div class=\"tr-why\">Row Level Security로 인증과 권한을 DB 레벨에서 처리. 별도 백엔드 없이 트리거·RPC로 서버사이드 로직을 구성했다.</div>\n        <div class=\"tr-dec\"><span class=\"dec-lbl\">결정 포인트</span>백엔드 없이 권한·자동화를 DB에서 해결</div>\n      </div>\n      <div class=\"tr\">\n        <div class=\"tr-name\"><div class=\"td\" style=\"background:#f38020\"></div><div><div class=\"tn\">Cloudflare Workers</div><div class=\"tc\">Edge Deployment</div></div></div>\n        <div class=\"tr-why\">OpenNext로 Next.js를 Workers 런타임으로 변환. 글로벌 엣지로 국내 사용자 레이턴시를 최소화하고 git push 시 자동 배포.</div>\n        <div class=\"tr-dec\"><span class=\"dec-lbl\">결정 포인트</span>응답 속도 + 자동 배포 파이프라인</div>\n      </div>\n      <div class=\"tr\">\n        <div class=\"tr-name\"><div class=\"td\" style=\"background:#336791\"></div><div><div class=\"tn\">PostgreSQL</div><div class=\"tc\">Database</div></div></div>\n        <div class=\"tr-why\">트리거로 매치 기록 즉시 통계 집계, 가입 시 연관 테이블 자동 초기화. 클라이언트 로직에서 누락이 생겨도 DB 레벨에서 정합성을 보장한다.</div>\n        <div class=\"tr-dec\"><span class=\"dec-lbl\">결정 포인트</span>트리거·RLS로 데이터 정합성을 서버에서 보장</div>\n      </div>\n      <div class=\"tr\">\n        <div class=\"tr-name\"><div class=\"td\" style=\"background:#61dafb\"></div><div><div class=\"tn\">React 19</div><div class=\"tc\">UI Library</div></div></div>\n        <div class=\"tr-why\">컴포넌트 기반으로 역할별 화면 16개를 구성. 코치 패널부터 키오스크 출석까지 하나의 컴포넌트 트리 안에서 관리한다.</div>\n        <div class=\"tr-dec\"><span class=\"dec-lbl\">결정 포인트</span>역할별 16개 화면을 단일 컴포넌트 트리로</div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- DESIGN DECISIONS -->\n<section class=\"section decisions-section\">\n  <div class=\"si\">\n    <span class=\"label-tag\">04 / Design</span>\n    <div class=\"big-head\">설계 과정에서<br>내린 판단들</div>\n    <div class=\"dec-grid\">\n      <div class=\"dc\">\n        <div class=\"dc-num\">Decision 01</div>\n        <div class=\"dc-title\">체육관 식별자를 3계층으로 분리했다</div>\n        <div class=\"dc-body\">초기엔 체육관 이름으로 회원을 연결했다. 오타와 동명 문제가 반복되자 <em>내부 연결 키 / 입력 코드 / 화면 표시 캐시</em>를 분리하는 구조로 재설계했다. 이후 이름 변경이나 오타가 데이터 정합성에 영향을 주지 않는다.</div>\n      </div>\n      <div class=\"dc\">\n        <div class=\"dc-num\">Decision 02</div>\n        <div class=\"dc-title\">별도 백엔드 없이 BaaS만으로 권한을 처리했다</div>\n        <div class=\"dc-body\">MVP 속도를 위해 별도 서버를 두지 않았다. 대신 <em>Row Level Security를 DB의 유일한 권한 경계</em>로 삼았다. 클라이언트 코드가 어떻게 변경되어도 DB 레벨에서 접근이 차단된다.</div>\n      </div>\n      <div class=\"dc\">\n        <div class=\"dc-num\">Decision 03</div>\n        <div class=\"dc-title\">게임화를 기능이 아닌 설계 원칙으로 뒀다</div>\n        <div class=\"dc-body\">포인트·스킬트리·가챠를 독립 기능으로 추가하는 대신, <em>출석 → 포인트 → 스킬트리 투자 → 카드 장착</em>의 순환 루프로 설계해 세 시스템이 서로를 강화하도록 연결했다.</div>\n      </div>\n      <div class=\"dc\">\n        <div class=\"dc-num\">Decision 04</div>\n        <div class=\"dc-title\">모바일을 별도 대응이 아닌 출발점으로 삼았다</div>\n        <div class=\"dc-body\">체육관 현장 사용이 핵심 시나리오다. <em>iPhone SE 375px를 기준점으로 잡고 확장</em>하는 방식으로 설계해, 키오스크 출석부터 코치 패널까지 단일 코드베이스로 동작한다.</div>\n      </div>\n      <div class=\"dc\">\n        <div class=\"dc-num\">Decision 05</div>\n        <div class=\"dc-title\">소속 이동 시 이력이 끊기지 않도록 설계했다</div>\n        <div class=\"dc-body\">선수가 체육관을 옮기면 기존 기록 컨텍스트가 사라지는 문제가 있었다. 경기 기록에 <em>당시 소속 스냅샷을 함께 저장</em>하고 이동 이력을 누적해 과거 기록이 원본 컨텍스트를 유지하도록 했다.</div>\n      </div>\n      <div class=\"dc\">\n        <div class=\"dc-num\">Decision 06</div>\n        <div class=\"dc-title\">공개 정보와 민감 정보를 DB 레벨에서 분리했다</div>\n        <div class=\"dc-body\">전적·티어는 공개하고 연락처·생년월일은 본인만 접근해야 한다. <em>두 종류를 별도 테이블에 분리</em>하고 공개 뷰를 통해서만 외부 접근이 가능하도록 설계해 민감 컬럼이 실수로 노출되는 경우를 차단했다.</div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- FOOTER -->\n<footer>\n  <div class=\"foot-inner\">\n    <div class=\"foot-l\">SPORTITION</div>\n    <div class=\"foot-r\">Sports Community Platform · MVP3<br>Next.js · Supabase · Cloudflare Workers</div>\n  </div>\n</footer>\n\n<script>\nconst canvas = document.getElementById('hero-canvas');\nlet W, H, nodes=[], t=0;\nconst RCOLS=[[100,160,220],[200,150,60],[192,57,43]];\n\nfunction resize(){\n  W=canvas.width=canvas.offsetWidth;\n  H=canvas.height=canvas.offsetHeight;\n  nodes=[];\n  const count=Math.min(Math.floor(W*H/16000),32);\n  for(let i=0;i<count;i++){\n    nodes.push({\n      x:Math.random()*W, y:Math.random()*H,\n      vx:(Math.random()-.5)*.18, vy:(Math.random()-.5)*.15,\n      r:Math.random()*.9+.4, a:Math.random()*.15+.03,\n      role:Math.random()<.2?Math.floor(Math.random()*3):-1\n    });\n  }\n}\n\nfunction draw(){\n  if(!canvas)return;\n  const ctx=canvas.getContext('2d');\n  ctx.clearRect(0,0,W,H);\n  const g=ctx.createRadialGradient(W*.5,H*.45,0,W*.5,H*.45,Math.max(W,H)*.8);\n  g.addColorStop(0,'#1a0a08'); g.addColorStop(.5,'#0e0d0b'); g.addColorStop(1,'#080807');\n  ctx.fillStyle=g; ctx.fillRect(0,0,W,H);\n  t+=.012;\n  for(let i=0;i<nodes.length;i++){\n    for(let j=i+1;j<nodes.length;j++){\n      const dx=nodes[i].x-nodes[j].x, dy=nodes[i].y-nodes[j].y, d=Math.sqrt(dx*dx+dy*dy);\n      if(d<110){ ctx.strokeStyle=`rgba(255,255,255,${.035*(1-d/110)})`; ctx.lineWidth=.4; ctx.beginPath(); ctx.moveTo(nodes[i].x,nodes[i].y); ctx.lineTo(nodes[j].x,nodes[j].y); ctx.stroke(); }\n    }\n  }\n  nodes.forEach(n=>{\n    n.x+=n.vx; n.y+=n.vy;\n    if(n.x<0)n.x=W; if(n.x>W)n.x=0; if(n.y<0)n.y=H; if(n.y>H)n.y=0;\n    if(n.role>=0){\n      const [r,g,b]=RCOLS[n.role], p=.6+Math.sin(t*1.3+n.x*.01)*.2;\n      const gw=ctx.createRadialGradient(n.x,n.y,0,n.x,n.y,14);\n      gw.addColorStop(0,`rgba(${r},${g},${b},.16)`); gw.addColorStop(1,`rgba(${r},${g},${b},0)`);\n      ctx.fillStyle=gw; ctx.beginPath(); ctx.arc(n.x,n.y,14,0,Math.PI*2); ctx.fill();\n      ctx.strokeStyle=`rgba(${r},${g},${b},${p*.7})`; ctx.lineWidth=1;\n      ctx.beginPath(); ctx.arc(n.x,n.y,4,0,Math.PI*2); ctx.stroke();\n      ctx.fillStyle=`rgba(${r},${g},${b},${p*.5})`; ctx.beginPath(); ctx.arc(n.x,n.y,2.5,0,Math.PI*2); ctx.fill();\n    } else {\n      ctx.fillStyle=`rgba(255,255,255,${n.a})`; ctx.beginPath(); ctx.arc(n.x,n.y,n.r,0,Math.PI*2); ctx.fill();\n    }\n  });\n  const vig=ctx.createRadialGradient(W/2,H/2,H*.1,W/2,H/2,H*.72);\n  vig.addColorStop(0,'rgba(0,0,0,0)'); vig.addColorStop(1,'rgba(0,0,0,.5)');\n  ctx.fillStyle=vig; ctx.fillRect(0,0,W,H);\n  requestAnimationFrame(draw);\n}\n\nwindow.addEventListener('load',()=>{resize();draw();});\nwindow.addEventListener('resize',resize);\n\n// Scroll reveal\nconst io=new IntersectionObserver(entries=>{\n  entries.forEach(e=>{\n    if(e.isIntersecting) e.target.classList.add('vis');\n  });\n},{threshold:0.1});\ndocument.querySelectorAll('.pi,.bc,.tr,.dc').forEach((el,i)=>{\n  el.style.transitionDelay=(i%8)*60+'ms';\n  io.observe(el);\n});\n</script>\n</body>\n</html>\n",
